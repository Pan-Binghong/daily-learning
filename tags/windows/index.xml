&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-json" data-lang="json">&lt;span class="line">&lt;span class="cl">&lt;span class="err">#&lt;/span> &lt;span class="err">推荐使用Ed&lt;/span>&lt;span class="mi">25519&lt;/span>&lt;span class="err">算法&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="err">ssh-keygen&lt;/span> &lt;span class="err">-t&lt;/span> &lt;span class="err">ed&lt;/span>&lt;span class="mi">25519&lt;/span> &lt;span class="err">-C&lt;/span> &lt;span class="s2">&amp;#34;your_email@example.com&amp;#34;&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="err">#&lt;/span> &lt;span class="err">备选&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="err">ssh-keygen&lt;/span> &lt;span class="err">-t&lt;/span> &lt;span class="err">rsa&lt;/span> &lt;span class="err">-b&lt;/span> &lt;span class="mi">4096&lt;/span> &lt;span class="err">-C&lt;/span> &lt;span class="s2">&amp;#34;your_email@example.com&amp;#34;&lt;/span>
