&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="err">ssh-add&lt;/span> &lt;span class="err">.\.ssh\id_ed&lt;/span>&lt;span class="mi">25519&lt;/span>
